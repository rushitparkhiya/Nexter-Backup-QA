# Copy to .env and fill in values before running tests.

# ── WordPress ──────────────────────────────────────────────────────────────────
WP_URL=http://localhost:8889
WP_ADMIN_USER=admin
WP_ADMIN_PASS=password
WP_EDITOR_USER=editor_test
WP_EDITOR_PASS=editorpass

# ── Second WP site for paired-site tests (TC111-113) ──────────────────────────
# Must be publicly routable — SSRF guard blocks 127.x/10.x/192.168.x
# WP_SITE_B_URL=http://site-b.example.test
# WP_SITE_B_NONCE=<REST nonce from Site B admin session>

# ── OAuth app credentials (TC101-103) ─────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DROPBOX_APP_KEY=
# DROPBOX_APP_SECRET=
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=

# ── S3-compatible / MinIO (TC104, TC106) ──────────────────────────────────────
# When using docker-compose.yml MinIO service:
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=nexterbackup-test

# ── SFTP (TC105) ──────────────────────────────────────────────────────────────
# When using docker-compose.yml sftp service:
# SFTP_HOST=sftp
# SFTP_PORT=22
# SFTP_USER=testuser
# SFTP_PASS=testpass

# ── WP-CLI (TC308) ────────────────────────────────────────────────────────────
# WP_CLI_AVAILABLE=1
# WP_CLI_PATH=/var/www/html
# WP_CLI_BIN=wp

# ── Fixture guards (set to 1 after seeding the respective fixture) ─────────────
# LARGE_UPLOADS_FIXTURE=1   # 1GB+ of files seeded in wp-content/uploads/
# BIG_DB_FIXTURE=1          # 100k+ posts seeded via wp post generate
# NON_UTF8_FIXTURE=1        # File with 0xFF bytes in name in uploads/
# SYMLINK_FIXTURE=1         # uploads/escape -> /etc/hosts symlink
# PERM_TEST_MODE=1          # Test framework can chmod storage dir
# DISABLE_WP_CRON_MODE=1    # define(DISABLE_WP_CRON, true) in wp-config.php
# OPENSSL_DISABLED=1        # disable_functions=openssl_encrypt in PHP ini
# SET_TIME_LIMIT_DISABLED=1 # disable_functions=set_time_limit in PHP ini
# FR_LOCALE_INSTALLED=1     # wp language plugin install nexter-extension fr_FR
